// SportFlow — Prisma schema
// Fonte da verdade dos dados. RLS habilitado em migration adicional (sql/rls-policies.sql).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================================
// ENUMS
// ==========================================================
enum TenantStatus {
  preview
  active
  suspended
  expired
}

enum UserRole {
  superadmin
  owner
  member
}

enum LicenseStatus {
  pending
  active
  expired
  cancelled
}

enum ChampionshipStatus {
  draft
  active
  finished
  cancelled
}

enum MatchStatus {
  scheduled
  live
  finished
  cancelled
}

enum TransactionType {
  income
  expense
}

enum ExportFormat {
  pdf
  csv
}

enum ExportStatus {
  pending
  processing
  completed
  failed
}

enum ConsentKind {
  privacy_policy
  terms_of_service
  email_marketing
  whatsapp_marketing
}

enum CampaignChannel {
  email
  whatsapp
}

enum CampaignStatus {
  draft
  scheduled
  sending
  sent
  failed
}

enum CampaignAudience {
  leads
  users_active
  users_preview
  users_all
}

enum DeliveryStatus {
  queued
  sent
  failed
  skipped_no_optin
  skipped_no_contact
}

// ==========================================================
// TENANT / USUARIO
// ==========================================================
model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  slug      String       @unique
  name      String
  email     String
  whatsapp  String?
  status    TenantStatus @default(preview)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  users         User[]
  licenses      License[]
  championships Championship[]
  participants  Participant[]
  matches       Match[]
  scoreEntries  ScoreEntry[]
  transactions  FinancialTransaction[]
  exports       ExportJob[]
  auditLogs     AuditLog[]

  @@index([status])
  @@map("tenants")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  email        String
  passwordHash String?   @map("password_hash")
  name         String
  role         UserRole  @default(member)
  googleId     String?   @unique @map("google_id")
  avatarUrl    String?   @map("avatar_url")
  optInEmail   Boolean   @default(false) @map("opt_in_email")
  optInWhatsapp Boolean  @default(false) @map("opt_in_whatsapp")
  lastLogin    DateTime? @map("last_login")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  auditLogs AuditLog[]
  consents  Consent[]
  deliveries CampaignDelivery[]

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([role])
  @@index([googleId])
  @@map("users")
}

// ==========================================================
// LICENCA
// ==========================================================
model License {
  id                  String        @id @default(uuid()) @db.Uuid
  tenantId            String        @map("tenant_id") @db.Uuid
  startsAt            DateTime?     @map("starts_at")
  expiresAt           DateTime?     @map("expires_at")
  durationDays        Int           @map("duration_days")
  priceBrl            Decimal       @map("price_brl") @db.Decimal(10, 2)
  stripeSessionId     String?       @map("stripe_session_id")
  stripePaymentId     String?       @map("stripe_payment_id")
  status              LicenseStatus @default(pending)
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([expiresAt])
  @@map("licenses")
}

// ==========================================================
// CAMPEONATO / PARTICIPANTE / JOGO
// ==========================================================
model Championship {
  id          String             @id @default(uuid()) @db.Uuid
  tenantId    String             @map("tenant_id") @db.Uuid
  name        String
  sportType   String             @map("sport_type")
  rulesConfig Json?              @map("rules_config")
  status      ChampionshipStatus @default(draft)
  startDate   DateTime?          @map("start_date")
  endDate     DateTime?          @map("end_date")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")

  tenant       Tenant                 @relation(fields: [tenantId], references: [id])
  participants Participant[]
  matches      Match[]
  transactions FinancialTransaction[]
  exports      ExportJob[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([sportType])
  @@map("championships")
}

model Participant {
  id             String    @id @default(uuid()) @db.Uuid
  championshipId String    @map("championship_id") @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  name           String
  category       String?
  metadata       Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  championship Championship @relation(fields: [championshipId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  homeMatches  Match[]      @relation("HomeParticipant")
  awayMatches  Match[]      @relation("AwayParticipant")
  scoreEntries ScoreEntry[]

  @@index([championshipId])
  @@index([tenantId])
  @@map("participants")
}

model Match {
  id                String      @id @default(uuid()) @db.Uuid
  championshipId    String      @map("championship_id") @db.Uuid
  tenantId          String      @map("tenant_id") @db.Uuid
  homeParticipantId String      @map("home_participant_id") @db.Uuid
  awayParticipantId String      @map("away_participant_id") @db.Uuid
  status            MatchStatus @default(scheduled)
  scheduledAt       DateTime?   @map("scheduled_at")
  finishedAt        DateTime?   @map("finished_at")
  liveToken         String      @unique @map("live_token")
  timerSeconds      Int         @default(0) @map("timer_seconds")
  timerRunning      Boolean     @default(false) @map("timer_running")
  timerStartedAt    DateTime?   @map("timer_started_at")
  homeScore         Int         @default(0) @map("home_score")
  awayScore         Int         @default(0) @map("away_score")
  scoreState        Json?       @map("score_state")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  championship     Championship @relation(fields: [championshipId], references: [id])
  tenant           Tenant       @relation(fields: [tenantId], references: [id])
  homeParticipant  Participant  @relation("HomeParticipant", fields: [homeParticipantId], references: [id])
  awayParticipant  Participant  @relation("AwayParticipant", fields: [awayParticipantId], references: [id])
  scoreEntries     ScoreEntry[]

  @@index([tenantId])
  @@index([championshipId])
  @@index([liveToken])
  @@index([status])
  @@map("matches")
}

model ScoreEntry {
  id            String   @id @default(uuid()) @db.Uuid
  matchId       String   @map("match_id") @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  participantId String   @map("participant_id") @db.Uuid
  delta         Int
  scoreData     Json     @map("score_data")
  updatedBy     String   @map("updated_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  match       Match       @relation(fields: [matchId], references: [id])
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  participant Participant @relation(fields: [participantId], references: [id])

  @@index([matchId])
  @@index([tenantId])
  @@map("score_entries")
}

// ==========================================================
// FINANCEIRO
// ==========================================================
model FinancialTransaction {
  id              String          @id @default(uuid()) @db.Uuid
  championshipId  String          @map("championship_id") @db.Uuid
  tenantId        String          @map("tenant_id") @db.Uuid
  type            TransactionType
  category        String
  amount          Decimal         @db.Decimal(12, 2)
  description     String?
  sponsorName     String?         @map("sponsor_name")
  transactionDate DateTime        @map("transaction_date")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  championship Championship @relation(fields: [championshipId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])

  @@index([championshipId])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([transactionDate])
  @@map("financial_transactions")
}

// ==========================================================
// EXPORTACAO
// ==========================================================
model ExportJob {
  id             String       @id @default(uuid()) @db.Uuid
  championshipId String       @map("championship_id") @db.Uuid
  tenantId       String       @map("tenant_id") @db.Uuid
  format         ExportFormat
  modules        Json
  status         ExportStatus @default(pending)
  fileUrl        String?      @map("file_url")
  errorMessage   String?      @map("error_message")
  completedAt    DateTime?    @map("completed_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  championship Championship @relation(fields: [championshipId], references: [id])
  tenant       Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@map("export_jobs")
}

// ==========================================================
// AUDITORIA
// ==========================================================
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  resource  String
  payload   Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([action])
  @@map("audit_logs")
}

// ==========================================================
// LEADS (funil de aquisicao para SuperAdmin)
// ==========================================================
model Lead {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String?   @map("tenant_id") @db.Uuid
  name        String
  email       String
  whatsapp    String
  sport       String
  source      String?
  optInEmail  Boolean   @default(false) @map("opt_in_email")
  optInWhatsapp Boolean @default(false) @map("opt_in_whatsapp")
  convertedAt DateTime? @map("converted_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  deliveries CampaignDelivery[]

  @@index([email])
  @@index([convertedAt])
  @@map("leads")
}

// ==========================================================
// CONSENTIMENTOS (LGPD)
// ==========================================================
// Cada aceite gera uma linha imutavel com versao da politica, IP e user
// agent. Revogar = criar novo Consent com accepted=false.
model Consent {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String?     @map("user_id") @db.Uuid
  leadId      String?     @map("lead_id") @db.Uuid
  tenantId    String?     @map("tenant_id") @db.Uuid
  kind        ConsentKind
  accepted    Boolean
  version     String
  ipAddress   String?     @map("ip_address")
  userAgent   String?     @map("user_agent")
  createdAt   DateTime    @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([leadId])
  @@index([kind])
  @@map("consents")
}

// ==========================================================
// CAMPANHAS DE MARKETING (SuperAdmin)
// ==========================================================
model Campaign {
  id          String           @id @default(uuid()) @db.Uuid
  title       String
  channel     CampaignChannel
  audience    CampaignAudience
  subject     String?
  body        String
  status      CampaignStatus   @default(draft)
  scheduledAt DateTime?        @map("scheduled_at")
  sentAt      DateTime?        @map("sent_at")
  sentCount   Int              @default(0) @map("sent_count")
  skippedCount Int             @default(0) @map("skipped_count")
  failedCount Int              @default(0) @map("failed_count")
  createdBy   String           @map("created_by") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  deliveries CampaignDelivery[]

  @@index([status])
  @@map("campaigns")
}

model CampaignDelivery {
  id         String         @id @default(uuid()) @db.Uuid
  campaignId String         @map("campaign_id") @db.Uuid
  userId     String?        @map("user_id") @db.Uuid
  leadId     String?        @map("lead_id") @db.Uuid
  channel    CampaignChannel
  contact    String
  status     DeliveryStatus
  errorMessage String?      @map("error_message")
  sentAt     DateTime?      @map("sent_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])
  lead     Lead?    @relation(fields: [leadId], references: [id])

  @@index([campaignId])
  @@index([userId])
  @@index([leadId])
  @@index([status])
  @@map("campaign_deliveries")
}
