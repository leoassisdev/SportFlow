# =========================
# DATABASE
# =========================
DATABASE_URL="postgresql://sportflow:sportflow_dev@localhost:5432/sportflow"

# =========================
# REDIS
# =========================
REDIS_URL="redis://localhost:6379"

# =========================
# JWT
# =========================
JWT_ACCESS_SECRET="troque-por-um-secret-de-no-minimo-32-caracteres-aqui"
JWT_REFRESH_SECRET="troque-por-outro-secret-de-no-minimo-32-caracteres-aqui"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# =========================
# STRIPE
# =========================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLIC_KEY="pk_test_..."

# =========================
# AZURE BLOB STORAGE (exportacoes)
# =========================
AZURE_BLOB_CONNECTION_STRING=""
AZURE_BLOB_CONTAINER="sportflow-exports"

# =========================
# APP CONFIG
# =========================
NODE_ENV="development"
API_PORT=3001
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"

# =========================
# FRONTEND (Next.js)
# =========================
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="http://localhost:3001"
NEXT_PUBLIC_USE_MOCK="true"
NEXT_PUBLIC_STRIPE_PUBLIC_KEY="pk_test_..."

# =========================
# EMAIL (opcional MVP)
# =========================
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
FROM_EMAIL="no-reply@sportflow.com.br"

# =========================
# OBSERVABILIDADE
# =========================
SENTRY_DSN=""
LOG_LEVEL="info"
